<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>デジタルマート株式会社｜中小企業のデジタル戦略、全部やります。</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Sora:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0a2e5c;
  --blue: #1558a8;
  --blue-mid: #2272cc;
  --sky: #4a9fe0;
  --pale: #f0f6fc;
  --pale2: #f7fafd;
  --accent: #e8890a;
  --accent-light: #fff4e0;
  --green: #1a9060;
  --text: #1a1a2e;
  --text-mid: #4a4a6a;
  --text-light: #8888aa;
  --border: #d0e4f5;
  --white: #ffffff;
  --shadow-sm: 0 2px 12px rgba(10,46,92,0.08);
  --shadow: 0 8px 32px rgba(10,46,92,0.12);
  --shadow-lg: 0 20px 60px rgba(10,46,92,0.18);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Noto Sans JP',sans-serif;color:var(--text);background:#fff;line-height:1.7;overflow-x:hidden;font-size:18px;}

/* ===== NAV ===== */
nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(255,255,255,0.97);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);height:68px;display:flex;align-items:center;justify-content:space-between;padding:0 40px;}
.logo a{text-decoration:none;}
.logo-mark{width:36px;height:36px;background:var(--blue);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.logo-mark svg{width:20px;height:20px;fill:white;}
.logo-text{font-family:'Sora',sans-serif;font-weight:700;font-size:18px;color:var(--navy);letter-spacing:0.04em;}
.nav-links{display:flex;align-items:center;gap:4px;}
.nav-link{font-size:14px;font-weight:500;color:var(--text-mid);text-decoration:none;padding:8px 14px;border-radius:6px;transition:all .15s;}
.nav-link:hover{color:var(--blue);background:var(--pale);}
.nav-right{display:flex;align-items:center;gap:12px;}
.nav-link-contact{font-size:14px;font-weight:500;color:var(--text-mid);text-decoration:none;padding:8px 14px;border-radius:6px;transition:all .15s;}
.nav-link-contact:hover{color:var(--blue);background:var(--pale);}
.nav-btn{background:var(--blue);color:#fff;padding:10px 22px;border-radius:6px;font-size:13px;font-weight:700;text-decoration:none;transition:all .2s;white-space:nowrap;}
.nav-btn:hover{background:var(--navy);}
.nav-hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;}
.nav-hamburger span{display:block;width:22px;height:2px;background:var(--navy);border-radius:2px;transition:all .3s;}

/* モバイルメニュー */
.mobile-menu{display:none;position:fixed;top:68px;left:0;right:0;background:#fff;border-bottom:1px solid var(--border);padding:16px 24px 24px;z-index:199;flex-direction:column;gap:4px;box-shadow:0 8px 24px rgba(0,0,0,.1);}
.mobile-menu a{font-size:16px;font-weight:500;color:var(--text-dark);text-decoration:none;padding:12px 16px;border-radius:8px;transition:background .15s;}
.mobile-menu a:hover{background:var(--pale);}
.mobile-menu-cta{background:var(--blue)!important;color:#fff!important;text-align:center;font-weight:700!important;margin-top:8px;}
.mobile-menu.open{display:flex;}

/* ===== FOOTER ===== */
footer{background:#1e3a5f;color:rgba(255,255,255,.75);}
.footer-inner{max-width:1100px;margin:0 auto;padding:60px 48px 32px;}
.footer-top{display:grid;grid-template-columns:280px 1fr;gap:64px;margin-bottom:48px;padding-bottom:48px;border-bottom:1px solid rgba(255,255,255,.1);}
.footer-brand{}
.footer-logo{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.footer-tagline{font-size:13px;line-height:1.8;color:rgba(255,255,255,.75);margin-bottom:16px;}
.footer-address{font-size:12px;line-height:1.9;color:rgba(255,255,255,.6);}
.footer-nav-group{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;}
.footer-nav-col{display:flex;flex-direction:column;gap:10px;}
.footer-nav-head{font-size:11px;font-weight:700;letter-spacing:.14em;color:rgba(255,255,255,.55);text-transform:uppercase;margin-bottom:4px;}
.footer-nav-col a{font-size:13px;color:rgba(255,255,255,.75);text-decoration:none;transition:color .15s;line-height:1.5;}
.footer-nav-col a:hover{color:#fff;}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;}
.footer-bottom p{font-size:12px;color:rgba(255,255,255,.5);}
.footer-bottom-links{display:flex;gap:20px;}
.footer-bottom-links a{font-size:12px;color:rgba(255,255,255,.55);text-decoration:none;transition:color .15s;}
.footer-bottom-links a:hover{color:rgba(255,255,255,.7);}

/* ===== HERO ===== */
.hero{min-height:74vh;background:#fff;display:flex;align-items:center;padding:80px 48px 40px;position:relative;overflow:hidden;}
.hero-bg-left{position:absolute;top:0;right:0;bottom:0;width:46%;background:linear-gradient(160deg,#f0f6fc 0%,#e4f0fb 100%);z-index:0;}
.hero-bg-accent{position:absolute;top:0;right:46%;width:3px;height:100%;background:linear-gradient(180deg,var(--blue-mid),var(--sky));z-index:1;}
.hero-inner{max-width:1100px;margin:0 auto;width:100%;display:grid;grid-template-columns:1.1fr 0.9fr;gap:48px;align-items:start;position:relative;z-index:2;}

/* 左エリア */
.hero-left{padding:20px 24px 0;}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--border);color:var(--blue-mid);font-size:13px;letter-spacing:0.08em;padding:7px 16px;border-radius:20px;margin-bottom:20px;box-shadow:var(--shadow-sm);}
.hero-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--blue-mid);flex-shrink:0;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.4;}}
.hero-h1{font-size:clamp(28px,3.4vw,50px);font-weight:900;color:var(--navy);line-height:1.3;margin-bottom:12px;letter-spacing:-0.02em;}
.hero-h1 .accent{color:var(--blue-mid);}
.hero-sub{font-size:15px;color:#666;line-height:1.6;margin-bottom:12px;font-weight:400;}
.hero-tagline{font-size:14px;font-weight:700;color:#444;line-height:1.5;margin-bottom:24px;}
.hero-btns{margin-bottom:10px;}
.btn-hero-primary{background:#1e5ca5;color:#fff;padding:0 32px;height:52px;border-radius:8px;font-size:16px;font-weight:700;text-decoration:none;box-shadow:0 6px 24px rgba(30,92,165,0.3);transition:all .2s;display:inline-flex;align-items:center;gap:8px;}
.btn-hero-primary::after{content:'→';}
.btn-hero-primary:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(30,92,165,0.4);background:var(--navy);}
.hero-btn-sub{font-size:12px;color:#999;line-height:1.5;}

/* 右エリア */
.hero-right{display:flex;flex-direction:column;gap:12px;padding-top:20px;}

/* 層1: 料金・サービス内容（ボタンなし） */
.hero-layer1{background:#e6f1fb;border:1px solid #0c447c;border-radius:8px;padding:24px;}
.hero-layer1-label{font-size:12px;color:#666;margin-bottom:12px;font-weight:600;}
.hero-layer1-title{font-size:18px;font-weight:700;color:var(--navy);margin-bottom:8px;line-height:1.4;}
.hero-layer1-price{font-family:'Sora',sans-serif;font-size:20px;font-weight:700;color:var(--navy);margin-bottom:16px;line-height:1;}
.hero-layer1-price span{font-size:13px;font-weight:400;color:#666;margin-left:4px;}
.hero-layer1-items{display:flex;flex-direction:column;gap:10px;}
.hero-layer1-item{display:flex;align-items:flex-start;gap:8px;font-size:14px;color:var(--text-mid);line-height:1.5;}
.hero-layer1-item::before{content:'✓';color:#1e5ca5;font-weight:700;flex-shrink:0;margin-top:1px;}

/* 層2: サービスカテゴリ（参考情報） */
.hero-sub-cards{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.hero-sub-card{background:#fff;border-radius:10px;padding:12px 14px;border:1px solid var(--border);}
.hero-sub-card-icon{margin-bottom:5px;}
.hero-sub-card strong{display:block;font-size:13px;font-weight:700;color:var(--navy);margin-bottom:1px;}
.hero-sub-card span{font-size:11px;color:var(--text-light);line-height:1.5;}

/* ===== MEDIA SLIDER ===== */
.media-strip{background:#fff;border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:16px 0;}
.media-strip-head{text-align:center;margin-bottom:12px;display:flex;align-items:center;justify-content:center;gap:16px;}
.media-strip-label{font-size:12px;font-weight:700;letter-spacing:.18em;color:var(--text-light);text-transform:uppercase;}
.media-strip-head::before,.media-strip-head::after{content:'';flex:1;max-width:80px;height:1px;background:var(--border);}
.media-strip-text{font-size:15px;color:var(--text-mid);}
.slider-wrap{overflow:hidden;position:relative;}
.slider-wrap::before,.slider-wrap::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none;}
.slider-wrap::before{left:0;background:linear-gradient(90deg,#fff,transparent);}
.slider-wrap::after{right:0;background:linear-gradient(-90deg,#fff,transparent);}
.slider-track{display:flex;gap:12px;width:max-content;}
.slide-left{animation:slide-left 32s linear infinite;}
.slide-right{animation:slide-right 32s linear infinite;}
.slider-track:hover{animation-play-state:paused;}
@keyframes slide-left{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
@keyframes slide-right{0%{transform:translateX(-50%);}100%{transform:translateX(0);}}
.slider-row-label{font-size:12px;font-weight:700;color:var(--text-light);letter-spacing:.06em;padding:0 24px;margin-bottom:8px;}
.media-logo{flex-shrink:0;}
.logo-pill{display:flex;align-items:center;gap:8px;padding:12px 22px;border-radius:40px;border:1.5px solid var(--border);font-size:16px;font-weight:700;white-space:nowrap;transition:all .2s;cursor:default;background:#fff;}
.logo-pill:hover{box-shadow:var(--shadow-sm);transform:translateY(-1px);}
.logo-pill span{font-size:15px;font-weight:600;}
.google{color:#4285f4;border-color:#e8f0fe;}
.google:hover{background:#f0f4ff;}
.meta{color:#0866ff;border-color:#dce8ff;}
.meta:hover{background:#f0f5ff;}
.instagram{color:#e1306c;border-color:#fde;background:linear-gradient(135deg,#fff 60%,#fff5f8);}
.instagram:hover{background:linear-gradient(135deg,#fff5f8,#fff0f5);}
.youtube{color:#ff0000;border-color:#ffe0e0;}
.youtube:hover{background:#fff5f5;}
.tiktok{color:#010101;border-color:#eee;}
.tiktok:hover{background:#f8f8f8;}
.line{color:#06c755;border-color:#d4f4e2;}
.line:hover{background:#f0fbf4;}
.x{color:#000;border-color:#e5e5e5;}
.x:hover{background:#f7f7f7;}
.yahoo{color:#ff0033;border-color:#ffe0e5;}
.yahoo:hover{background:#fff5f7;}
.linkedin{color:#0a66c2;border-color:#dce8f5;}
.linkedin:hover{background:#f0f6ff;}
.chatgpt{color:#10a37f;border-color:#d4f0e8;}
.chatgpt:hover{background:#f0fbf7;}
.claude{color:#7c3aed;border-color:#ede4ff;}
.claude:hover{background:#f8f5ff;}
.recruit{color:#e60012;border-color:#ffd6d9;}
.recruit:hover{background:#fff5f6;}
.doda{color:#ff6b00;border-color:#ffe0cc;}
.doda:hover{background:#fff8f3;}
.indeed{color:#003a9b;border-color:#d6e0f5;}
.indeed:hover{background:#f0f4ff;}
.engagejapan{color:#e8380d;border-color:#fdd8d0;}
.engagejapan:hover{background:#fff5f3;}
.wantedly{color:#21bcde;border-color:#cdf1f9;}
.wantedly:hover{background:#f0fbff;}
.googlejobs{color:#4285f4;border-color:#e8f0fe;}
.googlejobs:hover{background:#f0f4ff;}
.townwork{color:#e60020;border-color:#ffd6da;}
.townwork:hover{background:#fff5f6;}
.baito{color:#ff4f00;border-color:#ffdacc;}
.baito:hover{background:#fff8f3;}
.ga{color:#e37400;border-color:#fde8cc;}
.ga:hover{background:#fff8f0;}

/* ===== SECTION BASE ===== */
.section{padding:96px 48px;}
.container{max-width:1100px;margin:0 auto;}
.s-label{font-size:13px;font-weight:700;letter-spacing:0.22em;color:var(--blue-mid);text-transform:uppercase;margin-bottom:12px;}
.s-title{font-size:clamp(26px,3.2vw,44px);font-weight:800;color:var(--navy);line-height:1.35;margin-bottom:16px;}
.s-title span{color:var(--blue-mid);}
.s-desc{font-size:17px;color:var(--text-mid);line-height:1.9;max-width:620px;}
.center{text-align:center;}
.center .s-desc{margin:0 auto;}

/* ===== TROUBLE ===== */
.trouble{background:var(--pale2);}
.trouble-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:52px;}
.trouble-card{background:#fff;border-radius:14px;padding:28px 32px;border:1px solid var(--border);display:flex;gap:18px;align-items:flex-start;box-shadow:var(--shadow-sm);transition:box-shadow .2s;}
.trouble-card:hover{box-shadow:var(--shadow);}
.trouble-num{font-family:'Sora',sans-serif;font-size:28px;font-weight:700;color:var(--border);line-height:1;flex-shrink:0;margin-top:2px;}
.trouble-card h4{font-size:18px;font-weight:700;color:var(--navy);margin-bottom:6px;}
.trouble-card p{font-size:15px;color:var(--text-mid);line-height:1.8;}

/* ===== WHY COMPARE ===== */
.why-section{background:#fff;}
.compare-table{display:grid;grid-template-columns:1fr 64px 1fr;gap:0;margin-top:56px;align-items:stretch;}
.compare-col{border-radius:16px;overflow:hidden;}
.compare-bad{background:#fafafa;border:2px solid #e8e8e8;}
.compare-good{background:#f0f6fc;border:2px solid var(--blue-mid);box-shadow:0 8px 40px rgba(34,114,204,.15);}
.compare-col-head{padding:20px 28px;border-bottom:2px solid #e8e8e8;}
.compare-good .compare-col-head{border-color:var(--blue-mid);}
.compare-head-label{font-size:15px;font-weight:800;letter-spacing:.04em;padding:6px 18px;border-radius:4px;display:inline-block;}
.compare-head-label.bad{background:#f0f0f0;color:#888;}
.compare-head-label.good{background:var(--blue-mid);color:#fff;}
.compare-item{display:flex;gap:16px;align-items:flex-start;padding:20px 28px;border-bottom:1px solid #ebebeb;}
.compare-good .compare-item{border-color:rgba(34,114,204,.12);}
.compare-item:last-child{border:none;}
.compare-icon{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;flex-shrink:0;margin-top:2px;}
.compare-icon.bad{background:#fee;color:#c0392b;}
.compare-icon.good{background:#dff0ff;color:var(--blue-mid);}
.compare-item-title{font-size:16px;font-weight:700;color:var(--navy);margin-bottom:4px;}
.compare-bad .compare-item-title{color:#666;}
.compare-item-desc{font-size:13px;color:#999;line-height:1.75;}
.compare-good .compare-item-desc{color:var(--text-mid);}
.compare-vs{display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-size:18px;font-weight:700;color:var(--text-light);}
.why-wrap{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;margin-top:60px;}
.why-visual{position:relative;}
.why-box{background:var(--pale2);border-radius:16px;padding:32px;border:1px solid var(--border);}
.why-row{display:flex;gap:16px;padding:18px 0;border-bottom:1px solid var(--border);}
.why-row:last-child{border:none;padding-bottom:0;}
.why-tag{font-size:10px;font-weight:700;letter-spacing:.06em;padding:4px 12px;border-radius:4px;white-space:nowrap;align-self:flex-start;margin-top:3px;}
.tag-red{background:#fce8e8;color:#b91c1c;}
.tag-blue{background:#e0edff;color:#1e4fa0;}
.why-row-text{font-size:15px;color:var(--text-mid);line-height:1.75;}
.why-row-text strong{display:block;font-size:16px;font-weight:700;color:var(--text);margin-bottom:3px;}
.why-points{display:flex;flex-direction:column;gap:28px;}
.why-point{display:flex;gap:18px;align-items:flex-start;}
.why-icon{width:52px;height:52px;background:var(--pale);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.why-point-body strong{display:block;font-size:18px;font-weight:700;color:var(--navy);margin-bottom:4px;}
.why-point-body p{font-size:15px;color:var(--text-mid);line-height:1.8;}

/* ===== FLOW ===== */
.flow{background:var(--pale2);}
.flow-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:56px;position:relative;}
.flow-steps::before{content:'';position:absolute;top:60px;left:calc(33.3% - 16px);right:calc(33.3% - 16px);height:2px;background:linear-gradient(90deg,var(--blue-mid),var(--accent));z-index:0;}
.flow-step{text-align:center;position:relative;z-index:1;}
.flow-bubble{width:120px;height:120px;border-radius:50%;margin:0 auto 24px;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;}
.bubble-1{background:#fff;border:3px solid var(--blue-mid);box-shadow:0 4px 20px rgba(34,114,204,.15);}
.bubble-2{background:var(--accent);box-shadow:0 4px 20px rgba(232,137,10,.3);}
.bubble-3{background:#fff;border:3px solid var(--blue-mid);box-shadow:0 4px 20px rgba(34,114,204,.15);}
.flow-step-num{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--blue-mid);margin-bottom:2px;}
.bubble-2 .flow-step-num{color:rgba(255,255,255,.8);}
.flow-step-price{font-family:'Sora',sans-serif;font-size:19px;font-weight:700;color:var(--navy);}
.flow-step-price sup{font-size:11px;}
.flow-step-price sub{font-size:11px;font-weight:400;}
.bubble-2 .flow-step-price{color:#fff;}
.flow-step h4{font-size:17px;font-weight:700;color:var(--navy);margin-bottom:10px;}
.flow-step p{font-size:13px;color:var(--text-mid);line-height:1.85;}

/* ===== PLANS ===== */
.plans-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:56px;align-items:stretch;}
.plan{border-radius:16px;border:1.5px solid var(--border);background:#fff;padding:36px 28px;display:flex;flex-direction:column;transition:all .3s;position:relative;}
.plan:hover{box-shadow:var(--shadow);transform:translateY(-4px);}
.plan.star{border-color:var(--blue-mid);background:var(--navy);color:#fff;transform:translateY(-10px);box-shadow:var(--shadow-lg);}
.plan.star:hover{transform:translateY(-14px);}
.plan-badge{position:absolute;top:-15px;left:50%;transform:translateX(-50%);background:var(--accent);color:#fff;font-size:10px;font-weight:700;letter-spacing:.1em;padding:4px 18px;border-radius:20px;white-space:nowrap;}
.plan-head{margin-bottom:24px;padding-bottom:24px;border-bottom:1px solid var(--border);}
.star .plan-head{border-color:rgba(255,255,255,.15);}
.plan-tier{font-size:11px;font-weight:700;letter-spacing:.18em;color:var(--blue-mid);margin-bottom:6px;}
.star .plan-tier{color:rgba(255,255,255,.5);}
.plan-name{font-family:'Sora',sans-serif;font-size:22px;font-weight:700;color:var(--navy);margin-bottom:4px;}
.star .plan-name{color:#fff;}
.plan-for{font-size:14px;color:var(--text-light);line-height:1.6;}
.star .plan-for{color:rgba(255,255,255,.5);}
.plan-price{font-family:'Sora',sans-serif;font-size:38px;font-weight:700;color:var(--navy);letter-spacing:-.02em;margin-bottom:4px;}
.star .plan-price{color:#fcd34d;}
.plan-price-note{font-size:13px;color:var(--text-light);margin-bottom:20px;}
.star .plan-price-note{color:rgba(255,255,255,.65);}
.plan-result{background:var(--pale);border-radius:8px;padding:14px 16px;margin-bottom:20px;font-size:15px;font-weight:600;color:var(--navy);line-height:1.6;}
.star .plan-result{background:rgba(255,255,255,.1);color:rgba(255,255,255,.9);}
.plan-result::before{content:"✓ ";}
.plan-items{list-style:none;flex:1;margin-bottom:28px;}
.plan-items li{font-size:14px;color:var(--text-mid);padding:10px 0;border-bottom:1px solid var(--border);display:flex;gap:10px;line-height:1.6;}
.star .plan-items li{color:rgba(255,255,255,.7);border-color:rgba(255,255,255,.1);}
.plan-items li::before{content:"—";color:var(--sky);flex-shrink:0;}
.star .plan-items li::before{color:rgba(255,255,255,.5);}
.plan-btn{display:block;text-align:center;padding:16px;border-radius:8px;font-size:16px;font-weight:700;text-decoration:none;transition:all .2s;border:2px solid var(--blue-mid);color:var(--blue-mid);}
.plan-btn:hover{background:var(--blue-mid);color:#fff;}
.star .plan-btn{background:var(--accent);border-color:var(--accent);color:#fff;}
.star .plan-btn:hover{background:#d07a08;border-color:#d07a08;}

/* ===== SPOTS ===== */
.spots{background:var(--pale2);}
.spot-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:40px;}
.spot-item{background:#fff;border:1px solid var(--border);border-radius:10px;padding:20px 24px;display:flex;justify-content:space-between;align-items:center;gap:16px;transition:box-shadow .2s;}
.spot-item:hover{box-shadow:var(--shadow-sm);}
.spot-item-left{display:flex;align-items:center;gap:14px;}
.spot-emoji{font-size:24px;flex-shrink:0;}
.spot-name{font-size:16px;font-weight:600;color:var(--navy);}
.spot-note{font-size:13px;color:var(--text-light);margin-top:2px;}
.spot-price{font-family:'Sora',sans-serif;font-size:19px;font-weight:700;color:var(--navy);white-space:nowrap;}

/* ===== NUMBERS ===== */
.numbers{background:#1a4a82;}
.numbers-head{text-align:center;margin-bottom:56px;}
.numbers-head .s-label{color:rgba(255,255,255,.65);}
.numbers-head .s-title{color:#fff;}
.numbers-head .s-desc{color:rgba(255,255,255,.6);margin:0 auto;}
.num-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:rgba(255,255,255,.14);border-radius:16px;overflow:hidden;margin-bottom:40px;}
.num-item{background:rgba(255,255,255,.1);padding:36px 20px;text-align:center;}
.num-val{font-family:'Sora',sans-serif;font-size:52px;font-weight:700;color:#fcd34d;line-height:1;letter-spacing:-.02em;margin-bottom:8px;}
.num-val span{font-size:26px;}
.num-label{font-size:14px;color:rgba(255,255,255,.6);line-height:1.7;}
.num-label small{font-size:12px;opacity:.6;display:block;}
.case-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px;}
.case-card{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);border-radius:12px;padding:24px;}
.case-tag{font-size:11px;letter-spacing:.16em;color:rgba(255,255,255,.6);font-weight:700;margin-bottom:10px;}
.case-challenge{font-size:14px;color:rgba(255,255,255,.65);margin-bottom:14px;line-height:1.7;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.08);}
.case-results{display:flex;flex-direction:column;gap:6px;}
.case-result-item{font-size:15px;color:#fff;font-weight:500;}
.case-result-item em{font-style:normal;color:#fcd34d;font-weight:700;}
.clients{text-align:center;}
.clients-label{font-size:12px;letter-spacing:.2em;color:rgba(255,255,255,.5);font-weight:700;margin-bottom:20px;}
.clients-list{display:flex;flex-wrap:wrap;justify-content:center;gap:16px 32px;}
.clients-list span{font-size:15px;color:rgba(255,255,255,.65);font-weight:600;}

/* ===== PROFILE ===== */
.profile-wrap{display:grid;grid-template-columns:280px 1fr;gap:72px;align-items:start;margin-top:60px;}
.profile-photo{background:var(--pale);border-radius:20px;overflow:hidden;aspect-ratio:3/4;display:flex;align-items:center;justify-content:center;font-size:80px;border:1px solid var(--border);}
.profile-info{}
.profile-name-block{margin-bottom:28px;padding-bottom:28px;border-bottom:1px solid var(--border);}
.profile-name{font-size:28px;font-weight:800;color:var(--navy);margin-bottom:4px;}
.profile-title{font-size:15px;color:var(--text-light);}
.profile-bio{font-size:16px;color:var(--text-mid);line-height:1.95;margin-bottom:28px;}
.profile-tags{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px;}
.ptag{background:var(--pale);color:var(--navy);font-size:13px;font-weight:600;padding:6px 16px;border-radius:20px;border:1px solid var(--border);}
.career-list{display:flex;flex-direction:column;gap:0;}
.career-item{display:flex;gap:16px;padding:12px 0;border-bottom:1px solid var(--border);}
.career-item:last-child{border:none;}
.career-co{font-size:13px;font-weight:700;color:var(--navy);width:180px;flex-shrink:0;}
.career-role{font-size:13px;color:var(--text-mid);}

/* ===== STRENGTHS ===== */
.strengths{background:var(--pale2);}
.str-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:52px;}
.str-item{background:#fff;border-radius:14px;padding:32px;border:1px solid var(--border);display:flex;gap:20px;transition:box-shadow .2s;}
.str-item:hover{box-shadow:var(--shadow);}
.str-icon{width:52px;height:52px;background:var(--pale);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;}
.str-item h4{font-size:18px;font-weight:700;color:var(--navy);margin-bottom:6px;}
.str-item p{font-size:15px;color:var(--text-mid);line-height:1.85;}

/* ===== FAQ ===== */
.faq-list{margin-top:44px;display:flex;flex-direction:column;gap:12px;}
.faq-item{background:#fff;border-radius:10px;border:1px solid var(--border);overflow:hidden;box-shadow:var(--shadow-sm);}
.faq-q{padding:24px 28px;font-size:17px;font-weight:600;color:var(--navy);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:16px;user-select:none;}
.faq-q::after{content:'+';font-size:24px;font-weight:300;color:var(--blue-mid);flex-shrink:0;transition:transform .3s;}
.faq-item.open .faq-q::after{transform:rotate(45deg);}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease;}
.faq-a-inner{padding:0 28px 24px;font-size:16px;color:var(--text-mid);line-height:1.9;border-top:1px solid var(--border);padding-top:18px;}
.faq-item.open .faq-a{max-height:240px;}

/* ===== CTA ===== */
.cta-section{background:linear-gradient(135deg,#1558a8 0%,#2272cc 100%);padding:100px 48px;text-align:center;}
.cta-section h2{font-size:clamp(24px,3.5vw,44px);font-weight:800;color:#fff;line-height:1.4;margin-bottom:20px;}
.cta-section p{font-size:18px;color:rgba(255,255,255,.7);line-height:1.9;margin-bottom:52px;}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:28px;}
.btn-cta-primary{background:var(--accent);color:#fff;padding:22px 52px;border-radius:8px;font-size:18px;font-weight:700;text-decoration:none;box-shadow:0 6px 28px rgba(232,137,10,.45);transition:all .2s;}
.btn-cta-primary:hover{transform:translateY(-2px);}
.btn-cta-line{background:rgba(255,255,255,.12);color:#fff;border:1.5px solid rgba(255,255,255,.4);padding:22px 44px;border-radius:8px;font-size:18px;font-weight:500;text-decoration:none;transition:all .2s;}
.btn-cta-line:hover{background:rgba(255,255,255,.2);}
.cta-note{font-size:14px;color:rgba(255,255,255,.6);}

/* ===== INDUSTRY GRID ===== */
.industry-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:48px;}
.industry-item{background:#fff;border:1px solid var(--border);border-radius:12px;padding:20px 16px;text-align:center;transition:box-shadow .2s;}
.industry-item:hover{box-shadow:var(--shadow);}
.industry-icon{font-size:28px;margin-bottom:8px;}
.industry-name{font-size:13px;font-weight:600;color:var(--navy);line-height:1.5;}

/* ===== DIAGNOSIS DETAIL ===== */
.diag-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:48px;}
.diag-item{background:#fff;border-radius:14px;padding:28px 32px;border:1px solid var(--border);display:flex;gap:20px;align-items:flex-start;box-shadow:var(--shadow-sm);}
.diag-num{font-family:'Sora',sans-serif;font-size:32px;font-weight:700;color:var(--border);line-height:1;flex-shrink:0;}
.diag-body h4{font-size:17px;font-weight:700;color:var(--navy);margin-bottom:8px;}
.diag-body p{font-size:14px;color:var(--text-mid);line-height:1.85;}
.diag-cta{text-align:center;margin-top:48px;padding:40px;background:#fff;border-radius:16px;border:2px solid var(--blue-mid);}
.diag-cta-text{font-size:16px;color:var(--text-mid);line-height:1.9;margin-bottom:24px;}

/* ===== 9800 ENTRY CTA ===== */
.entry-cta-section{background:linear-gradient(135deg,#1558a8 0%,#2272cc 100%);padding:80px 48px;}
.entry-cta-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;}
.entry-cta-badge{display:inline-block;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:rgba(255,255,255,.9);font-size:12px;letter-spacing:.12em;padding:5px 16px;border-radius:20px;margin-bottom:20px;}
.entry-cta-title{font-size:clamp(28px,3.5vw,48px);font-weight:900;color:#fff;line-height:1.25;margin-bottom:16px;}
.entry-cta-title span{color:#fcd34d;}
.entry-cta-desc{font-size:16px;color:rgba(255,255,255,.75);line-height:1.85;margin-bottom:28px;}
.entry-cta-list{list-style:none;margin-bottom:32px;display:flex;flex-direction:column;gap:10px;}
.entry-cta-list li{font-size:15px;color:rgba(255,255,255,.85);font-weight:500;}
.entry-cta-btn{display:inline-block;background:#fcd34d;color:#0a2e5c;padding:18px 40px;border-radius:8px;font-size:17px;font-weight:800;text-decoration:none;transition:all .2s;box-shadow:0 6px 24px rgba(252,211,77,.3);}
.entry-cta-btn:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(252,211,77,.4);}
.entry-cta-price-card{background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.35);border-radius:20px;padding:40px;text-align:center;}
.ecp-label{font-size:13px;letter-spacing:.12em;color:rgba(255,255,255,.6);margin-bottom:8px;}
.ecp-price{font-family:'Sora',sans-serif;font-size:64px;font-weight:700;color:#fcd34d;line-height:1;letter-spacing:-.02em;margin-bottom:4px;}
.ecp-unit{font-size:14px;color:rgba(255,255,255,.5);margin-bottom:28px;}
.ecp-compare{background:rgba(255,255,255,.12);border-radius:10px;padding:16px;margin-bottom:16px;display:flex;flex-direction:column;gap:10px;}
.ecp-compare-item{display:flex;justify-content:space-between;align-items:center;gap:12px;font-size:13px;color:rgba(255,255,255,.75);}
.ecp-compare-highlight{color:#fff;font-weight:600;padding-top:10px;border-top:1px solid rgba(255,255,255,.1);}
.ecp-compare-val{white-space:nowrap;font-weight:700;}
.ecp-note{font-size:12px;color:rgba(255,255,255,.6);}

/* ===== PLAN ENTRY HIGHLIGHT ===== */
.plan-entry-highlight{border-color:var(--blue-mid);background:var(--pale);}

/* ===== SVG ICONS ===== */
.ic-svg{display:block;width:28px;height:28px;}
.ic-svg path,.ic-svg circle,.ic-svg rect,.ic-svg line,.ic-svg polyline,.ic-svg polygon{stroke-linecap:round;stroke-linejoin:round;}

/* ===== FOOTER ===== */
footer{background:#1e3a5f;color:rgba(255,255,255,.65);text-align:center;padding:36px 24px;font-size:14px;line-height:2.2;}
footer strong{color:rgba(255,255,255,.75);}

/* ===== FADE ===== */
.fade{opacity:0;transform:translateY(22px);transition:opacity .65s ease,transform .65s ease;}
.fade.in{opacity:1;transform:translateY(0);}

/* ===== RESPONSIVE ===== */
@media(max-width:900px){
  nav{padding:0 20px;}
  .nav-links,.nav-link-contact{display:none;}
  .nav-hamburger{display:flex;}
  .hero{padding:88px 24px 60px;}
  .hero-inner{grid-template-columns:1fr;}
  .hero-bg-left{display:none;}
  .hero-sub-cards{grid-template-columns:1fr 1fr;}
  .compare-table{grid-template-columns:1fr;}
  .compare-vs{padding:12px 0;}
  .flow-steps{grid-template-columns:1fr;}
  .flow-steps::before{display:none;}
  .plans-grid{grid-template-columns:1fr;}
  .spot-grid{grid-template-columns:1fr;}
  .num-grid{grid-template-columns:repeat(2,1fr);}
  .case-grid{grid-template-columns:1fr;}
  .profile-wrap{grid-template-columns:1fr;}
  .profile-photo{display:none;}
  .str-grid{grid-template-columns:1fr;}
  .industry-grid{grid-template-columns:repeat(2,1fr);}
  .diag-grid{grid-template-columns:1fr;}
  .entry-cta-inner{grid-template-columns:1fr;}
  .entry-cta-right{display:none;}
  .trouble-grid{grid-template-columns:1fr;}
  .footer-top{grid-template-columns:1fr;}
  .footer-nav-group{grid-template-columns:1fr 1fr;}
  .footer-inner{padding:40px 24px 24px;}
  .footer-bottom{flex-direction:column;text-align:center;}
  .section{padding:64px 24px;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">
    <a href="index.html" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
      <div class="logo-mark">
        <svg viewBox="0 0 24 24"><path d="M3 3h8v8H3zm10 0h8v8h-8zM3 13h8v8H3zm13 2a3 3 0 110 6 3 3 0 010-6z"/></svg>
      </div>
      <span class="logo-text">DIGITAL MART</span>
    </a>
  </div>
  <div class="nav-links">
    <a href="service.html" class="nav-link">サービス</a>
    <a href="cases.html" class="nav-link">実績</a>
    <a href="company.html" class="nav-link">会社概要</a>
