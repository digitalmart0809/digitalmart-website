    <button class="nav-hamburger" id="navHamburger" aria-label="メニュー">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <a href="service.html">サービス</a>
  <a href="cases.html">実績</a>
  <a href="company.html">会社概要</a>
  <a href="blog.html">ブログ</a>
  <a href="contact.html">お問い合わせ</a>
  <a href="contact.html" class="mobile-menu-cta">無料診断を申し込む（無料）</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg-left"></div>
  <div class="hero-bg-accent"></div>
  <div class="hero-inner">

    <!-- 左：メインメッセージ・CTA一本化 -->
    <div class="hero-left">
      <div class="hero-badge">中小企業専門　無料診断受付中</div>
      <h1 class="hero-h1">
        広告・SEO・採用。<br><span class="accent">中小企業のデジタル戦略、全部やります。</span>
      </h1>
      <p class="hero-sub">何から始めるべきか迷わない。デジタルマーケティング専門家に相談し放題。</p>
      <p class="hero-tagline">10年の経験で、中小企業のデジタル課題を解決。</p>
      <div class="hero-btns">
        <a href="#contact" class="btn-hero-primary">無料診断を申し込む（60分・無料）</a>
      </div>
      <p class="hero-btn-sub">※ 診断後の契約強要は一切ありません</p>
    </div>

    <!-- 右：情報提示のみ（ボタンなし） -->
    <div class="hero-right">

      <!-- 層1: 料金・サービス内容（ボタンなし） -->
      <div class="hero-layer1">
        <div class="hero-layer1-label">まずここから始める</div>
        <div class="hero-layer1-title">デジタルマーケの専門家に相談し放題</div>
        <div class="hero-layer1-price">¥9,800<span>/月（税別）</span></div>
        <div class="hero-layer1-items">
          <div class="hero-layer1-item">LINEまたはChatworkで相談し放題</div>
          <div class="hero-layer1-item">マーケ最新情報ニュースレター配信</div>
          <div class="hero-layer1-item">月1回の無料アドバイス（テキスト）</div>
          <div class="hero-layer1-item">いつでも解約OK・縛りなし</div>
        </div>
      </div>

      <!-- 層2: サービスカテゴリ（参考情報） -->
      <div class="hero-sub-cards">
        <div class="hero-sub-card">
          <div class="hero-sub-card-icon">
            <svg class="ic-svg" viewBox="0 0 24 24" fill="none" stroke="#2272cc" stroke-width="1.8"><path d="M22 9l-4 2V7l4 2z"/><rect x="2" y="7" width="12" height="10" rx="2"/></svg>
          </div>
          <strong>集客・広告</strong>
          <span>Google・Meta・SEO</span>
        </div>
        <div class="hero-sub-card">
          <div class="hero-sub-card-icon">
            <svg class="ic-svg" viewBox="0 0 24 24" fill="none" stroke="#1a9060" stroke-width="1.8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          </div>
          <strong>採用支援</strong>
          <span>戦略・媒体・原稿</span>
        </div>
        <div class="hero-sub-card">
          <div class="hero-sub-card-icon">
            <svg class="ic-svg" viewBox="0 0 24 24" fill="none" stroke="#e8890a" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2"/></svg>
          </div>
          <strong>AI活用</strong>
          <span>業務効率化</span>
        </div>
        <div class="hero-sub-card">
          <div class="hero-sub-card-icon">
            <svg class="ic-svg" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="1.8"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </div>
          <strong>戦略設計</strong>
          <span>課題整理から実行</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- MEDIA SLIDER -->
<section class="media-strip">
  <div class="media-strip-head">
    <span class="media-strip-label">対応媒体・ツール</span>
    <span class="media-strip-text">集客から採用まで、主要媒体・ツールすべてに対応します</span>
  </div>

  <!-- 集客・広告 → 左方向 -->
  <div class="slider-row-label">📣 集客・広告・SEO</div>
  <div class="slider-wrap" style="margin-bottom:10px;">
    <div class="slider-track slide-left">
      <div class="media-logo"><div class="logo-pill google">G <span>Google</span></div></div>
      <div class="media-logo"><div class="logo-pill meta">f <span>Meta広告</span></div></div>
      <div class="media-logo"><div class="logo-pill instagram">▣ <span>Instagram</span></div></div>
      <div class="media-logo"><div class="logo-pill youtube">▶ <span>YouTube</span></div></div>
      <div class="media-logo"><div class="logo-pill tiktok">♪ <span>TikTok</span></div></div>
      <div class="media-logo"><div class="logo-pill line">L <span>LINE広告</span></div></div>
      <div class="media-logo"><div class="logo-pill x">𝕏 <span>X広告</span></div></div>
      <div class="media-logo"><div class="logo-pill yahoo">Y! <span>Yahoo!広告</span></div></div>
      <div class="media-logo"><div class="logo-pill ga">GA <span>GA4</span></div></div>
      <div class="media-logo"><div class="logo-pill chatgpt">⬡ <span>ChatGPT</span></div></div>
      <div class="media-logo"><div class="logo-pill claude">◈ <span>Claude</span></div></div>
      <!-- duplicate -->
      <div class="media-logo"><div class="logo-pill google">G <span>Google</span></div></div>
      <div class="media-logo"><div class="logo-pill meta">f <span>Meta広告</span></div></div>
      <div class="media-logo"><div class="logo-pill instagram">▣ <span>Instagram</span></div></div>
      <div class="media-logo"><div class="logo-pill youtube">▶ <span>YouTube</span></div></div>
      <div class="media-logo"><div class="logo-pill tiktok">♪ <span>TikTok</span></div></div>
      <div class="media-logo"><div class="logo-pill line">L <span>LINE広告</span></div></div>
      <div class="media-logo"><div class="logo-pill x">𝕏 <span>X広告</span></div></div>
      <div class="media-logo"><div class="logo-pill yahoo">Y! <span>Yahoo!広告</span></div></div>
      <div class="media-logo"><div class="logo-pill ga">GA <span>GA4</span></div></div>
      <div class="media-logo"><div class="logo-pill chatgpt">⬡ <span>ChatGPT</span></div></div>
      <div class="media-logo"><div class="logo-pill claude">◈ <span>Claude</span></div></div>
    </div>
  </div>

  <!-- 採用 → 右方向 -->
  <div class="slider-row-label">🧑‍💼 採用・HR</div>
  <div class="slider-wrap">
    <div class="slider-track slide-right">
      <div class="media-logo"><div class="logo-pill recruit">R <span>リクナビNEXT</span></div></div>
      <div class="media-logo"><div class="logo-pill doda">d <span>doda</span></div></div>
      <div class="media-logo"><div class="logo-pill indeed">in <span>Indeed</span></div></div>
      <div class="media-logo"><div class="logo-pill engagejapan">e <span>エン転職</span></div></div>
      <div class="media-logo"><div class="logo-pill wantedly">w <span>Wantedly</span></div></div>
